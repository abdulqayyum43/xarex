# =============================================================================
# Xarex Cloud Brain — Environment Configuration
# =============================================================================
# Copy to .env and fill in real values:
#   cp .env.example .env
#   chmod 600 .env
#
# NEVER commit .env to source control.
# =============================================================================

# ── Database (Required) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://xarex:change-me@localhost:5432/xarex

# ── Server (Required) ────────────────────────────────────────────────────────
SECRET_KEY=change-me-secret-key
GRPC_PORT=50051
WS_PORT=8005

# `development` | `staging` | `production`. Used by startup safety checks
# (e.g. emits a warning when sk_live_* is paired with a non-production env).
ENVIRONMENT=development

# ── Admin (Required) ─────────────────────────────────────────────────────────
# Secret header value for /api/v1/admin/* routes — keep private.
# Generate: openssl rand -hex 32
ADMIN_SECRET=change-me-admin-secret

# ── CORS / Browser origins ───────────────────────────────────────────────────
# Comma-separated allowlist of origins permitted to call the API from a
# browser. Use `null` to allow file:// origins (Chrome sets origin to "null"
# when opening website/index.html directly from disk during dev).
CORS_ORIGINS=http://localhost:8005,http://127.0.0.1:8005,http://localhost:5173,http://127.0.0.1:5173,null

# ── AI Analysis (Optional) ───────────────────────────────────────────────────
# Enables the AI Security Analyst (Claude). Leave blank to disable.
ANTHROPIC_API_KEY=

# ── CVE Intelligence (Optional) ──────────────────────────────────────────────
# Raises NVD rate limit from 5 req/30s to 50 req/30s.
# Register: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ── Notifications (Optional) ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Automation ───────────────────────────────────────────────────────────────
AUTO_ENRICH_CVE=true
AUTO_GENERATE_REPORT=true
AUTO_AI_ANALYSIS=false
NOTIFY_ON_SCAN_COMPLETE=false

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Public URL ───────────────────────────────────────────────────────────────
# Used to build webhook/callback/redirect URLs.
PUBLIC_URL=http://localhost:8005

# =============================================================================
# Billing — Stripe
# =============================================================================
# Get keys from https://dashboard.stripe.com/apikeys (toggle Test/Live mode).
# TEST keys: sk_test_*, LIVE keys: sk_live_*. Never mix in the same env.
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret. Obtain by either:
#   - Registering a webhook endpoint at https://dashboard.stripe.com/webhooks
#     (production / a public dev URL like a tunnel), OR
#   - Running `stripe listen --forward-to localhost:8005/api/billing/webhook/stripe`
#     locally — the CLI prints a whsec_... for the session.
STRIPE_WEBHOOK_SECRET=whsec_...

# Tiered pricing matrix. Create one Product + recurring Price per slot in
# the Stripe Dashboard, then paste the price_... IDs below.
#   Starter — Xarex Starter   ($49 / mo, $470 / yr)
#   Pro     — Xarex Pro       ($199 / mo, $1900 / yr)
# Empty slots cause the matching tier/cadence to return HTTP 400 at checkout
# with a "contact sales" message — safe default for partial rollouts.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# Display-only currency for receipts / emails. Actual currency is baked into
# each Stripe Price object and cannot be overridden at checkout time.
STRIPE_CURRENCY=usd

# Time-based trial in days. Set to 0 — we use a usage-based trial via the
# free plan's FREE_PLAN_SCAN_LIMIT (2 scans by default).
STRIPE_TRIAL_DAYS=0

# DEPRECATED — kept for compatibility with any legacy callers. Use the
# STRIPE_PRICE_* tier matrix above for new code.
STRIPE_PRICE_ID=
STRIPE_PRODUCT_ID=

# =============================================================================
# Billing — ToyyibPay (Malaysia, optional)
# =============================================================================
TOYYIBPAY_SECRET_KEY=
TOYYIBPAY_CATEGORY_CODE=
TOYYIBPAY_AMOUNT_CENTS=9900
TOYYIBPAY_SANDBOX=true

# =============================================================================
# Email — Resend or SMTP
# =============================================================================
# Resend (preferred). Get an API key at https://resend.com
RESEND_API_KEY=
# Before verifying your domain, use onboarding@resend.dev as the sender.
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=Xarex Security

# SMTP fallback (used only when RESEND_API_KEY is empty)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# =============================================================================
# Free Plan
# =============================================================================
FREE_PLAN_ENABLED=true
# Default trial: 2 scans on the free license before the user must upgrade.
FREE_PLAN_SCAN_LIMIT=2

# =============================================================================
# Lead capture (marketing site sample-report gate)
# =============================================================================
# Hard-delete leads older than this many days.
LEAD_RETENTION_DAYS=730
# Null out ip_address / user_agent on leads older than this many days.
LEAD_PII_RETENTION_DAYS=90

# Cloudflare Turnstile (anti-bot). Optional — leave empty to bypass during
# dev. Pair the server-side secret here with the site key on the marketing
# site via window.XAREX_TURNSTILE_SITE_KEY.
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# =============================================================================
# Rate limiting (slowapi)
# =============================================================================
# Optional Redis URI for cross-worker rate limit state.
# Leave empty for in-memory (per-process) limits. REQUIRED for multi-worker
# deployments — see services/billing.py::_REVEAL_TOKENS for related caveats.
RATE_LIMIT_STORAGE_URI=
