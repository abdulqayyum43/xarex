# =============================================================================
# Xarex — Production Environment Configuration
# =============================================================================
# Used by docker-compose.prod.yml.
# Copy to .env and fill in real values.
#
#   cp .env.example .env
#   chmod 600 .env
#
# NEVER commit .env to source control.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Used by the postgres container — also injected into Cloud Brain via compose
POSTGRES_USER=xarex
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=xarex

# ── Security ──────────────────────────────────────────────────────────────────
# Generate both with: openssl rand -hex 32
ADMIN_SECRET=change-me-admin-secret
SECRET_KEY=change-me-secret-key

# ── AI Analysis (Optional) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── CVE Intelligence (Optional) ───────────────────────────────────────────────
NVD_API_KEY=

# ── Notifications (Optional) ──────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Automation ────────────────────────────────────────────────────────────────
AUTO_ENRICH_CVE=true
AUTO_GENERATE_REPORT=true
AUTO_AI_ANALYSIS=false
NOTIFY_ON_SCAN_COMPLETE=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
ENVIRONMENT=production

# =============================================================================
# Billing
# =============================================================================

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_PRODUCT_ID=prod_...
STRIPE_CURRENCY=myr
# Register webhook at: https://yourdomain.com/api/billing/webhook/stripe
# Events: checkout.session.completed, invoice.payment_succeeded,
#         invoice.payment_failed, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# ── ToyyibPay ─────────────────────────────────────────────────────────────────
TOYYIBPAY_SECRET_KEY=your-toyyibpay-secret
TOYYIBPAY_CATEGORY_CODE=your-category-code
TOYYIBPAY_AMOUNT_CENTS=9900
TOYYIBPAY_SANDBOX=false

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@xarexsec.io
EMAIL_FROM_NAME=Xarex Security

# ── Free Plan ─────────────────────────────────────────────────────────────────
FREE_PLAN_ENABLED=true
FREE_PLAN_SCAN_LIMIT=3

# ── Docker image (optional — only needed when pulling from a registry) ────────
# REGISTRY=ghcr.io/your-org
# VERSION=latest
